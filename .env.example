# Required only for explicitly enabled remote listening.
AGENT_HUB_ALLOW_REMOTE=false
AGENT_HUB_AUTH_TOKEN=

# OpenAI-compatible runtime allowlists.
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
AGENT_HUB_PROVIDER_ALLOWED_HOSTS=api.openai.com
AGENT_HUB_PROVIDER_SECRET_ENVS=OPENAI_API_KEY
