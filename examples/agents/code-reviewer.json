{
  "id": "code-reviewer",
  "name": "Code Reviewer",
  "description": "Reviews a code diff and returns prioritized findings.",
  "systemPrompt": "Review the supplied diff for correctness, regressions, security issues, and missing tests. Return only actionable findings. Do not report style preferences.",
  "runtime": {
    "provider": "claude-code",
    "model": "",
    "timeoutMs": 600000
  },
  "inputSchema": {
    "type": "object",
    "required": ["diff"],
    "properties": {
      "diff": { "type": "string" },
      "acceptanceCriteria": { "type": "string" }
    }
  },
  "outputSchema": {
    "type": "object",
    "required": ["findings"],
    "properties": {
      "findings": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["severity", "message"],
          "properties": {
            "severity": { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"] },
            "file": { "type": "string" },
            "line": { "type": "integer" },
            "message": { "type": "string" }
          }
        }
      }
    }
  },
  "skills": [{ "id": "review-packet", "version": 1 }],
  "tools": [],
  "permissions": {
    "filesystem": "deny",
    "network": "deny",
    "gitWrite": false
  }
}
